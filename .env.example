# ═══════════════════════════════════════════════
# Alice — OpenClaw + Signal + Ollama
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your keys.
# ═══════════════════════════════════════════════

# OpenRouter — cloud model fallback (optional)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Ollama — local models (no key needed, enables discovery)
OLLAMA_API_KEY=ollama-local

# Gateway auth token (auto-generated on first run, or set your own)
OPENCLAW_GATEWAY_TOKEN=

# Timezone
TZ=America/New_York

# Signal: configured in openclaw.json after signal-cli registration

# WhatsApp: no token needed, uses QR code pairing

# ── Integrations ──

# Composio — 500+ app integrations (Gmail, Google Drive, Slack, etc.)
# Get your key at: https://composio.dev
COMPOSIO_API_KEY=

# ── Gateway ──

# Auto-generated during onboarding; leave blank for first setup
OPENCLAW_GATEWAY_TOKEN=

# ── General ──

# Your timezone (for cron jobs and reminders)
TZ=America/New_York
