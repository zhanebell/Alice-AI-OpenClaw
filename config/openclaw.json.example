{
  "browser": {
    "enabled": true
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://ollama:11434",
        "apiKey": "ollama-local",
        "api": "ollama",
        "models": [
          {
            "id": "qwen2.5:3b",
            "name": "Qwen 2.5 3B",
            "reasoning": false,
            "input": ["text"],
            "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 },
            "contextWindow": 32768,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/qwen2.5:3b",
        "fallbacks": [
          "openrouter/openrouter/free"
        ]
      },
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "signal": {
      "enabled": true,
      "httpUrl": "http://signal-cli:8080",
      "autoStart": false,
      "account": "+YOUR_SIGNAL_NUMBER",
      "dmPolicy": "pairing",
      "allowFrom": ["+YOUR_PERSONAL_NUMBER"],
      "groupPolicy": "disabled",
      "sendReadReceipts": true,
      "mediaMaxMb": 8,
      "textChunkLimit": 4000
    }
  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ]
    },
    "auth": {
      "mode": "token",
      "token": "__SET_VIA_OPENCLAW_GATEWAY_TOKEN_ENV_VAR__"
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.3.13"
  }
}
